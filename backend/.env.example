# Copy to .env and fill in your values. Do not commit .env.

# Supabase (from project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Airia (from Agent Studio > Settings > Interfaces > View API Info)
AIRIA_WEBHOOK_URL=https://api.airia.ai/v2/PipelineExecution/your-pipeline-guid
AIRIA_API_KEY=your-airia-api-key
